cc_library_static {
    name: "libsmbios_parser",
    vendor_available: true,
    min_sdk_version: "30",
    srcs: [
        "smbios.c",
    ],
    cflags: [
        "-std=c99",
        "-Wno-conversion",
        "-Wno-sign-compare",
    ],
    export_include_dirs: ["."],
}
